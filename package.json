{
  "name": "mokeb-al-shohada-qom",
  "version": "1.0.0",
  "description": "Desktop rest lounge management app for Mokeb Al-Shohada Qom",
  "author": "Mokeb Al-Shohada Qom",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "dist:win32": "npm run build && electron-builder --win --ia32",
    "dist:win64": "npm run build && electron-builder --win --x64",
    "dist:win32:installer": "npm run build && electron-builder --win nsis --ia32",
    "dist:win64:installer": "npm run build && electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "ir.qom.mokeb.alshohada",
    "productName": "Mokeb Al-Shohada Qom",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Mokeb-Al-Shohada-Qom-${version}-win-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mokeb Al-Shohada Qom"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^4.5.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
